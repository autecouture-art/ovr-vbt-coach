# Constants
APP_IDENTIFIER = 'com.autecouture.repvelocoach.hh'
TEAM_ID = 'NN9FMT4BC9'
WORKSPACE = 'ios/RepVeloCoach.xcworkspace'
SCHEME = 'RepVeloCoach'
OUTPUT_DIRECTORY = 'ios/fastlane_export'
OUTPUT_NAME = 'RepVeloCoach.ipa'
BUILD_PATH = 'ios/build'
ARCHIVE_PATH = 'ios/build/RepVeloCoach.xcarchive'
PROFILE_NAME = 'RepVeloCoach AppStore HealthKit'
PROFILE_FILENAME = 'RepVeloCoach_AppStore.mobileprovision'
CODE_SIGN_IDENTITY = 'Apple Distribution'

default_platform(:ios)

platform :ios do
  # Helper method to create App Store Connect API key
  private_lane :create_api_key do
    key_path = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV.fetch('ASC_KEY_ID')}.p8")

    app_store_connect_api_key(
      key_id: ENV.fetch('ASC_KEY_ID'),
      issuer_id: ENV.fetch('ASC_ISSUER_ID'),
      key_filepath: key_path,
      duration: 1200,
      in_house: false
    )
  end

  desc 'Build and upload to TestFlight'
  lane :beta do
    api_key = create_api_key

    sigh(
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      team_id: TEAM_ID,
      provisioning_name: PROFILE_NAME,
      skip_certificate_verification: true,
      filename: PROFILE_FILENAME
    )

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: 'Release',
      export_method: 'app-store',
      clean: true,
      output_directory: OUTPUT_DIRECTORY,
      output_name: OUTPUT_NAME,
      build_path: BUILD_PATH,
      archive_path: ARCHIVE_PATH,
      export_team_id: TEAM_ID,
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='#{PROFILE_NAME}' CODE_SIGN_IDENTITY='#{CODE_SIGN_IDENTITY}'",
      export_options: {
        signingStyle: 'manual',
        provisioningProfiles: {
          APP_IDENTIFIER => PROFILE_NAME
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "#{OUTPUT_DIRECTORY}/#{OUTPUT_NAME}",
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc 'Upload existing IPA to TestFlight'
  lane :upload_only do
    api_key = create_api_key

    upload_to_testflight(
      api_key: api_key,
      ipa: "#{OUTPUT_DIRECTORY}/#{OUTPUT_NAME}",
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
